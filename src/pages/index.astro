---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/photos/waschtisch-eiche.jpg';
import serviceImg1 from '../assets/photos/waschtisch-schwebend.jpg';
import serviceImg2 from '../assets/photos/dachschraegenschrank-led.jpg';
import serviceImg3 from '../assets/photos/trennwaende-buero.jpg';
import tile1 from '../assets/photos/sitzfenster.jpg';
import tile2 from '../assets/photos/schlafzimmerschrank-anthrazit.jpg';
import tile3 from '../assets/photos/garderobe-eckbank.jpg';
import tile4 from '../assets/photos/kommode-weiss.jpg';
import tile5 from '../assets/photos/dachschraegenschrank-led.jpg';
import tile6 from '../assets/photos/weinregal-eiche.png';
import tile7 from '../assets/photos/wandkommode-eiche.jpg';
import tile8 from '../assets/photos/badschrank-eiche.jpg';
import tile9 from '../assets/photos/schranktreppe.jpg';

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "GeneralContractor"],
  "name": "Schreinerei Hergert",
  "description": "Maßmöbel, Innenausbau und Gewerbelösungen seit 1928 – inhabergeführt in 3. Generation.",
  "image": "https://www.schreinereihergert.de/assets/logo-hergert.png",
  "url": "https://www.schreinereihergert.de/",
  "telephone": "+49 621 771352",
  "email": "schreinerei-hergert@t-online.de",
  "foundingDate": "1928",
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Schönauer Str. 14",
    "addressLocality": "Mannheim-Sandhofen",
    "addressRegion": "Baden-Württemberg",
    "postalCode": "68307",
    "addressCountry": "DE"
  },
  "areaServed": [
    { "@type": "City", "name": "Mannheim" },
    { "@type": "AdministrativeArea", "name": "Rhein-Neckar-Region" }
  ],
  "knowsAbout": ["Maßmöbel", "Innenausbau", "Einbauschränke", "Schrankwände", "Trennwände", "Gewerbeeinrichtung"],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "description": "Termine nach Vereinbarung"
  }
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet ein Maßmöbel bei Schreinerei Hergert?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Kosten hängen von Abmessungen, Materialwahl und Ausführung ab. Einfache Einbauschränke beginnen bei ca. 1.500 €, aufwendigere Schrankwände oder komplette Innenausbauten entsprechend mehr. Wir erstellen Ihnen gerne ein kostenloses, unverbindliches Angebot nach einem persönlichen Beratungsgespräch."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert die Fertigung eines Maßmöbels?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Je nach Projektumfang und Auftragslage dauert die Fertigung in der Regel 4 bis 8 Wochen ab Auftragserteilung. Bei komplexeren Projekten wie vollständigem Innenausbau kann es etwas länger sein. Im Erstgespräch nennen wir Ihnen eine konkrete Einschätzung für Ihr Vorhaben."
      }
    },
    {
      "@type": "Question",
      "name": "In welchem Gebiet ist Schreinerei Hergert tätig?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wir sind hauptsächlich in Mannheim und der gesamten Rhein-Neckar-Region tätig – darunter Ludwigshafen, Heidelberg, Schwetzingen, Viernheim und Weinheim. Unsere Werkstatt befindet sich in Mannheim-Sandhofen und ist gut über die B44 erreichbar."
      }
    }
  ]
});

const QUOTES = [
  { quote: 'Unser Dachgeschoss war wegen der Schrägen kaum nutzbar. Daraus wurde ein Einbauschrank, der jeden Winkel nutzt. Gute Beratung, saubere Arbeit.', name: 'M. Steinbach', meta: 'Privatkunde, Mannheim-Rheinau' },
  { quote: 'Empfangstheke und Büroeinrichtung für unsere neuen Räume – termingerecht, maßgenau und ohne Komplikationen. Sehr zu empfehlen.', name: 'J. Kramer', meta: 'Geschäftsführerin, Mannheim' },
  { quote: 'Professionelle Beratung, pünktliche Ausführung. Der Einbauschrank ist exakt so geworden, wie wir ihn uns vorgestellt haben. Sehr gerne wieder!', name: 'Familie Müller', meta: 'Privatkunden, Mannheim-Neckarau' },
];
---

<Layout
  title="Schreinerei Hergert – Ihr Schreiner in Mannheim | Maßmöbel & Innenausbau seit 1928"
  description="Schreinerei Hergert in Mannheim-Sandhofen: Maßmöbel, Innenausbau und Gewerbelösungen seit 1928 – inhabergeführt in 3. Generation. Jetzt unverbindlich anfragen."
  active="home"
  canonical="https://www.schreinereihergert.de/"
  schemas={[localBusinessSchema, faqSchema]}
>
  <!-- Hero -->
  <section class="h-section h-section--tight" style="padding-top: var(--space-7);">
    <div class="h-wrap">
      <div class="h-hero-grid">
        <div style="display: flex; flex-direction: column; gap: var(--space-4);">
          <span class="h-eyebrow">Seit 1928 · Mannheim-Sandhofen</span>
          <h1 style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-hero); line-height: 1.05; letter-spacing: -0.02em; color: var(--text-heading); margin: 0;">
            Ihr Schreiner in Mannheim – Maßmöbel &amp; Innenausbau
          </h1>
          <p style="font-family: var(--font-sans); font-size: var(--text-lg); line-height: 1.7; color: var(--text-secondary); max-width: 520px; margin: 0;">
            Inhabergeführt, 3. Generation. Wir fertigen, was es so nicht zu kaufen gibt – präzise, regional und mit Blick fürs Detail.
          </p>
          <div style="display: flex; gap: var(--space-3); margin-top: var(--space-2); flex-wrap: wrap;">
            <a href="/kontakt" class="btn btn--primary btn--lg" style="white-space: nowrap;">
              Jetzt anfragen
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/leistungen" class="btn btn--secondary btn--lg" style="white-space: nowrap;">Unsere Leistungen</a>
          </div>
          <div style="display: flex; align-items: center; gap: var(--space-2); margin-top: var(--space-2); font-size: var(--text-sm); color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--oak-600);" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            Antwort in der Regel innerhalb eines Werktags
          </div>
        </div>
        <div style="position: relative;">
          <div class="h-frame" style="border-radius: var(--radius-xl); box-shadow: var(--shadow-lg); aspect-ratio: 4 / 5;">
            <Image src={heroImg} alt="Maßgefertigter Doppelwaschtisch aus Eiche mit Ablage-Nische" loading="eager" fetchpriority="high" width={1400} height={900} />
          </div>
          <div style="position: absolute; left: var(--space-3); bottom: var(--space-3); background: var(--white); border-radius: var(--radius-md); box-shadow: var(--shadow-lg); padding: 16px 20px; display: flex; gap: var(--space-4);">
            <div style="display: flex; flex-direction: column; gap: 4px;">
              <span style="font-family: var(--font-display); font-size: 38px; font-weight: 600; line-height: 1; color: var(--text-heading); letter-spacing: -0.02em;">98</span>
              <span style="font-family: var(--font-sans); font-size: var(--text-sm); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em;">Jahre</span>
            </div>
            <div style="width: 1px; background: var(--border-subtle);"></div>
            <div style="display: flex; flex-direction: column; gap: 4px;">
              <span style="font-family: var(--font-display); font-size: 38px; font-weight: 600; line-height: 1; color: var(--oak-600); letter-spacing: -0.02em;">3.</span>
              <span style="font-family: var(--font-sans); font-size: var(--text-sm); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em;">Generation</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="h-section" style="background: #FFFFFF;">
    <div class="h-wrap">
      <div style="max-width: 700px;">
        <span class="h-eyebrow">Leistungen</span>
        <h2 style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h2); line-height: 1.15; letter-spacing: -0.01em; color: var(--text-heading); margin: var(--space-3) 0 var(--space-3);">Unsere Leistungen im Überblick</h2>
        <p style="font-family: var(--font-sans); font-size: var(--text-lg); line-height: 1.7; color: var(--text-secondary); margin: 0;">Vom maßgefertigten Einzelstück bis zum kompletten Innenausbau realisieren wir individuelle Wünsche für Privat- und Gewerbekunden.</p>
      </div>
      <div class="h-cols-3" style="margin-top: var(--space-6);">
        {[
          { eyebrow: 'Möbel nach Maß', title: 'Maßgeschreinert, nicht von der Stange', img: serviceImg1, body: 'Wir fertigen, was es so nicht zu kaufen gibt – präzise, langlebig und ganz nach Ihren individuellen Wünschen.' },
          { eyebrow: 'Innenausbau', title: 'Raumpotenzial voll ausschöpfen', img: serviceImg2, body: 'Passgenaue Einbauten schaffen Stauraum und Ordnung – für jede Nische, jede Dachschräge, jeden Winkel.' },
          { eyebrow: 'Gewerbelösungen', title: 'Maßarbeit für Unternehmen', img: serviceImg3, body: 'Empfangsbereiche, Teeküchen, Trennwände oder Staubschutz – maßgeschneidert für Büro, Praxis und Handel.' },
        ].map((s) => (
          <div class="h-card-lift">
            <a href="/leistungen" class="card">
              <div class="card__image" style="aspect-ratio: 4 / 3;">
                <Image src={s.img} alt={s.title} width={600} height={450} loading="lazy" />
              </div>
              <div class="card__body">
                <span style="font-family: var(--font-sans); font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #B12E34;">{s.eyebrow}</span>
                <h3 class="card__title">{s.title}</h3>
                <p class="card__desc">{s.body}</p>
              </div>
              <div class="card__footer">
                <span class="btn btn--ghost btn--sm">
                  Mehr erfahren
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section class="h-section" style="background: #F1ECE3;">
    <div class="h-wrap">
      <div style="max-width: 700px;">
        <span class="h-eyebrow">Referenzen</span>
        <h2 style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h2); line-height: 1.15; letter-spacing: -0.01em; color: var(--text-heading); margin: var(--space-3) 0 var(--space-3);">Ausgewählte Arbeiten</h2>
        <p style="font-family: var(--font-sans); font-size: var(--text-lg); line-height: 1.7; color: var(--text-secondary); margin: 0;">Ein Auszug aus Projekten in Mannheim und der Region – Innenausbau, maßgefertigte Möbel und mehr.</p>
      </div>
      <div class="h-portfolio" style="margin-top: var(--space-6);">
        {[
          { img: tile1, caption: 'Sitzfenster', meta: 'Eiche · mit Stauraum' },
          { img: tile2, caption: 'Einbauschrank', meta: 'Anthrazit · Schiebeleiter' },
          { img: tile3, caption: 'Garderobe', meta: 'Eiche · Eckbank' },
          { img: tile4, caption: 'Ankleide', meta: 'Weiß · grifflos' },
          { img: tile5, caption: 'Dachschräge', meta: 'Weiß · LED-Beleuchtung' },
          { img: tile6, caption: 'Weinregal', meta: 'Eiche · beleuchtet' },
          { img: tile7, caption: 'Wandkommode', meta: 'Eiche · schwebend' },
          { img: tile8, caption: 'Badschrank', meta: 'Eiche · Spiegelschrank' },
          { img: tile9, caption: 'Schranktreppe', meta: 'Stauraum unter der Treppe' },
        ].map((t) => (
          <figure class="photo-tile">
            <div class="photo-tile__img" style="aspect-ratio: 3 / 4;">
              <Image src={t.img} alt={`${t.caption} – ${t.meta}`} width={400} height={533} loading="lazy" />
            </div>
            <figcaption class="photo-tile__cap">
              <span class="photo-tile__caption">{t.caption}</span>
              <span class="photo-tile__meta">{t.meta}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust (dark) -->
  <section class="h-section" style="background: #1C1C1C;">
    <div class="h-wrap">
      <div class="h-split">
        <div style="border-radius: var(--radius-lg); background: rgba(160,120,80,0.12); border: 1px dashed #BD9B73; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; min-height: clamp(340px, 48vw, 520px); position: relative;">
          <span style="font-family: var(--font-display); font-size: 52px; font-weight: 600; color: #876545; line-height: 1;">AH</span>
          <div style="font-family: var(--font-sans); font-size: 14px; font-weight: 500; color: #876545; margin-top: 4px;">Axel Hergert</div>
          <div style="font-family: var(--font-sans); font-size: 12px; color: #BD9B73; letter-spacing: 0.04em;">Inhaber · 3. Generation</div>
        </div>
        <div style="display: flex; flex-direction: column; gap: var(--space-5);">
          <div>
            <span style="font-family: var(--font-sans); font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #BD9B73; display: inline-block; line-height: 1.4;">
              Familienbetrieb seit 1928
              <span style="display: block; width: 24px; height: 2px; background: #BD9B73; margin-top: 6px;"></span>
            </span>
            <h2 style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h2); line-height: 1.12; letter-spacing: -0.02em; color: #FFFFFF; margin: var(--space-4) 0 var(--space-3);">
              98 Jahre Schreinerhandwerk in Mannheim
            </h2>
            <p style="font-family: var(--font-sans); font-size: var(--text-base); line-height: 1.75; color: #E9CDA2; margin: 0;">
              Was 1928 als kleine Schreinerei in Mannheim-Sandhofen begann, führen wir heute in dritter Generation. Inhabergeführt von Anfang an – mit der Sorgfalt und Verlässlichkeit, der Privat- und Gewerbekunden seit Generationen vertrauen.
            </p>
          </div>
          <div style="display: flex; gap: var(--space-6); flex-wrap: wrap;">
            {[{ v: '1928', l: 'gegründet' }, { v: '98', l: 'Jahre Erfahrung' }, { v: '3.', l: 'Generation' }].map(({ v, l }) => (
              <div style="display: flex; flex-direction: column; gap: 6px;">
                <span style="font-family: var(--font-display); font-weight: 600; font-size: 76px; line-height: 1; color: #BD9B73; letter-spacing: -0.03em;">{v}</span>
                <span style="font-family: var(--font-sans); font-size: var(--text-sm); color: #E9CDA2; text-transform: uppercase; letter-spacing: 0.08em;">{l}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="h-section" style="background: #F3E7D3;">
    <div class="h-wrap">
      <div style="display: flex; flex-direction: column; align-items: center; gap: var(--space-5);">
        <span class="h-eyebrow">Was Kunden sagen</span>
        <div style="position: relative; max-width: 680px; width: 100%;">
          <span aria-hidden="true" style="position: absolute; top: -40px; left: -16px; font-family: var(--font-display); font-size: 140px; color: #B12E34; opacity: 0.2; line-height: 1; pointer-events: none; user-select: none; z-index: 0;">&ldquo;</span>
          <div style="position: relative; z-index: 1;">
            {QUOTES.map((q, i) => (
              <div class={`testimonial-slide${i === 0 ? ' is-active' : ''}`} data-index={i}>
                <figure style="margin: 0; background: var(--white); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-sm);">
                  <blockquote style="margin: 0; font-family: var(--font-display); font-size: var(--text-lg); line-height: 1.65; color: var(--text-body); font-style: italic;">
                    <p style="margin: 0;">&ldquo;{q.quote}&rdquo;</p>
                  </blockquote>
                  <figcaption style="margin-top: var(--space-4); display: flex; flex-direction: column; gap: 2px;">
                    <strong style="font-family: var(--font-sans); font-weight: 600; font-size: var(--text-base); color: var(--text-heading);">{q.name}</strong>
                    <span style="font-family: var(--font-sans); font-size: var(--text-sm); color: var(--text-muted);">{q.meta}</span>
                  </figcaption>
                </figure>
              </div>
            ))}
          </div>
        </div>
        <div style="display: flex; align-items: center; gap: var(--space-3); margin-top: var(--space-2);">
          <button id="prev-btn" aria-label="Vorheriges" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: var(--radius-sm); background: transparent; border: 1px solid var(--border-default); cursor: pointer; color: var(--text-body);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          </button>
          <div style="display: flex; gap: 8px;">
            {QUOTES.map((_, n) => (
              <button class="testimonial-dot" data-n={n} aria-label={`Stimme ${n + 1}`} style={`border: none; cursor: pointer; width: ${n === 0 ? '24px' : '8px'}; height: 8px; border-radius: 999px; background: ${n === 0 ? 'var(--oak-500)' : 'var(--cream-400)'}; transition: all 0.2s ease;`}></button>
            ))}
          </div>
          <button id="next-btn" aria-label="Nächstes" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: var(--radius-sm); background: transparent; border: 1px solid var(--border-default); cursor: pointer; color: var(--text-body);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="h-section h-section--tight">
    <div class="h-wrap">
      <div style="max-width: 680px;">
        <span class="h-eyebrow">FAQ</span>
        <h2 style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h2); line-height: 1.15; letter-spacing: -0.01em; color: var(--text-heading); margin: var(--space-3) 0 0;">Häufig gestellte Fragen</h2>
      </div>
      <div style="max-width: 720px; margin-top: var(--space-6); border-top: 1px solid var(--border-subtle);">
        {[
          { q: 'Was kostet ein Maßmöbel bei Schreinerei Hergert?', a: 'Die Kosten hängen von Abmessungen, Materialwahl und Ausführung ab. Einfache Einbauschränke beginnen bei ca. 1.500 €, aufwendigere Schrankwände oder komplette Innenausbauten entsprechend mehr. Wir erstellen Ihnen gerne ein kostenloses, unverbindliches Angebot nach einem persönlichen Beratungsgespräch.' },
          { q: 'Wie lange dauert die Fertigung eines Maßmöbels?', a: 'Je nach Projektumfang und Auftragslage dauert die Fertigung in der Regel 4 bis 8 Wochen ab Auftragserteilung. Bei komplexeren Projekten wie vollständigem Innenausbau kann es etwas länger sein. Im Erstgespräch nennen wir Ihnen eine konkrete Einschätzung für Ihr Vorhaben.' },
          { q: 'In welchem Gebiet ist Schreinerei Hergert tätig?', a: 'Wir sind hauptsächlich in Mannheim und der gesamten Rhein-Neckar-Region tätig – darunter Ludwigshafen, Heidelberg, Schwetzingen, Viernheim und Weinheim. Unsere Werkstatt befindet sich in Mannheim-Sandhofen und ist gut über die B44 erreichbar.' },
        ].map((item) => (
          <details class="faq-item">
            <summary>
              {item.q}
              <span class="faq-chevron" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </span>
            </summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.testimonial-slide');
  const dots = document.querySelectorAll<HTMLElement>('.testimonial-dot');
  let current = 0;

  function show(n: number) {
    slides.forEach((s, i) => s.classList.toggle('is-active', i === n));
    dots.forEach((d, i) => {
      d.style.width = i === n ? '24px' : '8px';
      d.style.background = i === n ? 'var(--oak-500)' : 'var(--cream-400)';
    });
    current = n;
  }

  document.getElementById('prev-btn')?.addEventListener('click', () => show((current - 1 + slides.length) % slides.length));
  document.getElementById('next-btn')?.addEventListener('click', () => show((current + 1) % slides.length));
  dots.forEach((d) => d.addEventListener('click', () => show(Number(d.dataset.n))));
</script>
