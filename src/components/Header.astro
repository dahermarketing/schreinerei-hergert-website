---
import { Image } from 'astro:assets';
import logoImg from '../assets/logo-hergert.png';

interface Props {
  active?: string;
}
const { active = '' } = Astro.props;

const NAV = [
  { label: 'Home', href: '/', key: 'home' },
  { label: 'Leistungen', href: '/leistungen', key: 'leistungen' },
  { label: 'Über uns', href: '/ueber-uns', key: 'ueber' },
  { label: 'Karriere', href: '/karriere', key: 'karriere' },
  { label: 'Kontakt', href: '/kontakt', key: 'kontakt' },
];
---

<header id="site-header" class="h-header">
  <div class="h-header__bar">
    <a class="h-logo" href="/" aria-label="Schreinerei Hergert — Startseite">
      <Image src={logoImg} alt="Schreinerei Hergert" width={760} height={190} loading="eager" />
    </a>
    <nav class="h-nav" aria-label="Hauptnavigation">
      <ul class="h-nav__list">
        {NAV.map((l) => (
          <li>
            <a class={`h-nav__link${active === l.key ? ' is-active' : ''}`}
              href={l.href}
              aria-current={active === l.key ? 'page' : undefined}>{l.label}</a>
          </li>
        ))}
      </ul>
      <a href="/kontakt" class="h-nav-cta btn btn--primary btn--sm" style="white-space: nowrap;">
        Anfragen <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <button id="menu-open" class="h-burger" aria-label="Menü öffnen" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </nav>
  </div>
</header>

<div id="drawer-scrim" class="h-drawer-scrim"></div>
<aside id="drawer" class="h-drawer" inert>
  <div class="h-drawer__top">
    <Image src={logoImg} alt="Schreinerei Hergert" width={760} height={190} style="height: 34px; width: auto;" loading="eager" />
    <button id="menu-close" class="h-burger" style="display: inline-flex;" aria-label="Menü schließen">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>
  <ul class="h-drawer__links">
    {NAV.map((l) => (
      <li>
        <a class={active === l.key ? 'is-active' : ''} href={l.href}>
          {l.label}
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </li>
    ))}
  </ul>
  <div class="h-drawer__cta">
    <a href="/kontakt" class="btn btn--primary btn--full">
      Jetzt anfragen
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
    <a class="h-drawer__call" href="tel:+496217711352">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.07 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      0621 771352
    </a>
  </div>
</aside>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const scrim = document.getElementById('drawer-scrim');
  const drawer = document.getElementById('drawer');
  const openBtn = document.getElementById('menu-open');
  const closeBtn = document.getElementById('menu-close');

  function openDrawer() {
    drawer?.classList.add('is-open');
    scrim?.classList.add('is-open');
    drawer?.removeAttribute('inert');
    openBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    drawer?.classList.remove('is-open');
    scrim?.classList.remove('is-open');
    drawer?.setAttribute('inert', '');
    openBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  scrim?.addEventListener('click', closeDrawer);
  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));
</script>
